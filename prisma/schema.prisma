generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./data.db"
}

model kayttaja {
  id             Int    @id @default(autoincrement())
  kayttajatunnus String
  salasana       String

  suosikit   suosikki[]  // Suosikit-suhde käyttäjälle
}

model suosikki {
  id         Int      @id @default(autoincrement())
  kayttajaId Int      
  kiekkoId   String   
  nimi       String
  valmistaja String
  kategoria  String?
  nopeus     String
  liito      String
  vakaus     String
  feidi      String
  kuva       String?
  stability  String?

  kayttaja   kayttaja @relation(fields: [kayttajaId], references: [id]) 
}
